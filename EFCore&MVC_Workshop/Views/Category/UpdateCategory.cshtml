@model Category //Modelimizi tanımladık ki formdan gelen verileri yakalayabilelim
@{
    ViewData["Title"] = "UpdateCategory";
    Layout = "~/Views/Layout/Index.cshtml";
}
<div class="row">
    <div class="col-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Kategori Güncelleme Sayfası</h4>
                <form class="forms-sample" method="post">
                    <!--fermun methodu post olarak belirlendi /BACKENDE POST TETIKLENDİĞİNDE ÇALIŞACAK YER-->
                    <div class="form-group">
                        <input type="hidden" asp-for="CategoryId" /><!--Gizli bir alan oluşturduk ki id yi de yakalayabilelim-->
                        <label for="exampleInputName1">kategori Adı</label>
                        <input type="text" class="form-control" id="exampleInputName1" placeholder="Kategori Adını Yazınız"
                               asp-for="CategoryName"><!--Bu alanın kimin için çalışacağını belirledik /MODEL KISMINDAN GELDİ-->
                    </div>
                    <button type="submit" class="btn btn-success mr-2">Kategoriyi Güncelle</button>
                </form>
            </div>
        </div>
    </div>
</div>

